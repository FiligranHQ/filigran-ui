{
  "name": "@filigran/chatbot",
  "description": "Filigran chat panel — React + Tailwind standalone chatbot component",
  "author": "Filigran",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FiligranHQ/filigran-ui.git"
  },
  "version": "3.0.3",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "NODE_ENV=development rollup --watch --config rollup.config.js",
    "build": "NODE_ENV=production rollup --config rollup.config.js",
    "check-ts": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts*\"",
    "lint-fix": "eslint --fix \"src/**/*.ts*\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "prepack": "yarn build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=10",
    "remark-gfm": ">=4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "22.19.1",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "rollup": "4.59.0",
    "rollup-plugin-dts": "6.3.0",
    "rollup-plugin-livereload": "2.0.5",
    "rollup-plugin-postcss": "4.0.2",
    "rollup-plugin-serve": "3.0.0",
    "rollup-plugin-typescript-paths": "1.5.0",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
